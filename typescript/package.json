{
  "name": "@codex-client/typescript",
  "version": "0.1.0",
  "description": "TypeScript bindings for the Codex app-server protocol.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "examples:build": "tsc -p tsconfig.examples.json",
    "example:quickstart": "pnpm examples:build && node ./.examples-dist/examples/01_quickstart.js",
    "example:streaming": "pnpm examples:build && node ./.examples-dist/examples/02_streaming_turn.js",
    "example:resume": "pnpm examples:build && node ./.examples-dist/examples/03_resume_thread.js",
    "example:approval": "pnpm examples:build && node ./.examples-dist/examples/04_approval_policy.js",
    "example:low-level": "pnpm examples:build && node ./.examples-dist/examples/05_low_level_client.js",
    "generate": "node ./scripts/generate-protocol-client.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
